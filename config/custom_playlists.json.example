{
  "playlists": [
    {
      "name": "Breakcore Mix (auto)",
      "description": "",
      "tags": ["breakcore", "drill and bass"],
      "match": "any",
      "limit": 50,
      "backfill": true,
      "privacy": "PUBLIC",
      "blacklist": ["artist name|wrong song title"],
      "blacklist_artists": ["unwanted artist"]
    },
    {
      "name": "Chill Electronic (auto)",
      "tags": ["ambient", "downtempo", "chillout"],
      "match": "any",
      "limit": 30,
      "backfill": false
    },
    {
      "name": "Rock Essentials (auto)",
      "tags": ["rock", "alternative rock", "indie rock"],
      "match": "any",
      "limit": 75
    },
    {
      "name": "My Favorite Artists (auto)",
      "kind": "artists",
      "artists": ["radiohead", "aphex twin"],
      "limit": 50,
      "backfill": true
    },
    {
      "name": "Discover Weekly (auto)",
      "kind": "discovery",
      "discovery_seed": "artists",
      "limit": 50,
      "privacy": "PRIVATE"
    },
    {
      "name": "Discover from Favourite Artists",
      "kind": "discovery",
      "discovery_seed": "artists",
      "discovery_seed_auto": false,
      "discovery_seed_artists": ["radiohead", "boards of canada"],
      "limit": 50,
      "privacy": "PRIVATE"
    },
    {
      "name": "Discover from Favourite Tracks",
      "kind": "discovery",
      "discovery_seed": "tracks",
      "discovery_seed_auto": false,
      "discovery_seed_tracks": [
        { "artist": "Radiohead", "track": "Weird Fishes/Arpeggi" },
        { "artist": "Aphex Twin", "track": "Xtal" }
      ],
      "discovery_exclude_scrobbled": false,
      "limit": 50,
      "privacy": "PRIVATE"
    },
    {
      "name": "Top Tracks - Last 30 Days",
      "kind": "filter",
      "filter_template": "top_tracks_30d",
      "limit": 50,
      "privacy": "PRIVATE"
    },
    {
      "name": "Forgotten Favorites",
      "kind": "filter",
      "filter_template": "forgotten_favorites",
      "limit": 50,
      "privacy": "PRIVATE"
    },
    {
      "name": "Summer Rewind",
      "kind": "filter",
      "filter_template": "custom",
      "filters": {
        "months": [6, 7, 8],
        "min_plays": 3,
        "sort": "plays"
      },
      "limit": 60,
      "privacy": "PRIVATE"
    }
  ]
}
