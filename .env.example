# ============================================================================
# CREDENTIALS (Required)
# ============================================================================

# Last.fm API - Get yours at https://www.last.fm/api/account/create
LASTFM_USER=
LASTFM_API_KEY=

# YouTube Music auth
YTM_AUTH_PATH=browser.json

# ============================================================================
# MAIN PLAYLIST
# ============================================================================

PLAYLIST_NAME=Last.fm Recents (auto)
PLAYLIST_DESCRIPTION=         # Custom description (empty = auto-generated)
PLAYLIST_PRIVACY=PRIVATE     # PRIVATE, UNLISTED, or PUBLIC (preferred)
MAKE_PUBLIC=                 # Deprecated alias for PLAYLIST_PRIVACY (boolean form warns)
LIMIT=100                    # Target number of tracks (API rate limit: ~3k/day)
DEDUPLICATE=true             # Remove duplicate tracks

# ============================================================================
# TRACK RANKING
# ============================================================================

USE_RECENCY_WEIGHTING=true   # Rank by play count + recency (false = most recent first)
RECENCY_HALF_LIFE_HOURS=48.0 # How fast recency decays (lower = favor newer tracks)
RECENCY_PLAY_WEIGHT=0.7      # Balance: 0.0 = pure recency, 1.0 = pure play count
RECENCY_MIN_PLAYS=1          # Minimum scrobbles within fetched window for a track to qualify (1 = no gate)

# ============================================================================
# WEEKLY PLAYLISTS
# ============================================================================

WEEKLY_ENABLED=true
WEEKLY_WEEK_START=MON        # MON|TUE|WED|THU|FRI|SAT|SUN
WEEKLY_TIMEZONE=UTC          # IANA tz name (e.g. Europe/Berlin, America/New_York)
WEEKLY_KEEP_WEEKS=2          # How many weeks to keep (0 = keep all)
WEEKLY_PLAYLIST_PREFIX=      # Override name (empty = derive from PLAYLIST_NAME)
WEEKLY_PLAYLIST_PRIVACY=     # PRIVATE/UNLISTED/PUBLIC (empty = inherit PLAYLIST_PRIVACY)
WEEKLY_MAKE_PUBLIC=          # Deprecated alias for WEEKLY_PLAYLIST_PRIVACY

# ============================================================================
# SEARCH BEHAVIOR
# ============================================================================

USE_ANON_SEARCH=true         # Use anonymous YTM client for searches (keeps queries out of your YouTube search history)
EARLY_TERMINATION_SCORE=0.9  # Stop search early if match score exceeds this (0.0-1.0)
SLEEP_BETWEEN_SEARCHES=0.25  # Delay between searches in seconds
SEARCH_MAX_WORKERS=2         # Parallel search threads (higher = faster but more API load)

# ============================================================================
# BACKFILL (Fetching more tracks when duplicates reduce count)
# ============================================================================

MAX_RAW_SCROBBLES=2000       # Max scrobbles to fetch (0 = unlimited)
BACKFILL_PASSES=3            # Additional fetch attempts if below LIMIT (0 = disabled)

# ============================================================================
# CACHING
# ============================================================================

CACHE_PLAYLIST_FILE=cache/.playlist_cache.json
CACHE_SEARCH_FILE=cache/.search_cache.json
CACHE_OVERRIDES_FILE=config/search_overrides.json
CACHE_SEARCH_TTL_DAYS=30     # Days before cached searches expire (0 = never)
CACHE_NOTFOUND_TTL_DAYS=7    # Days before "not found" results are retried (0 = don't cache)

# ============================================================================
# CUSTOM TAG PLAYLISTS
# ============================================================================

CUSTOM_PLAYLISTS_FILE=config/custom_playlists.json  # Path to custom playlist config
CUSTOM_PLAYLISTS_PRIVACY=              # PRIVATE/UNLISTED/PUBLIC (empty = inherit PLAYLIST_PRIVACY)
TAG_CACHE_FILE=cache/.tag_cache.json   # Path to tag cache file
TAG_CACHE_TTL_DAYS=90                  # Days before cached tags expire
TAG_MIN_COUNT=10                       # Minimum Last.fm tag vote count to consider valid
TAG_SLEEP_BETWEEN=0.25                 # Delay between tag API calls in seconds
TAG_OVERRIDES_FILE=config/tag_overrides.json  # Manual tag overrides file (add/replace modes)

# ============================================================================
# HISTORY DATABASE
# ============================================================================

HISTORY_DB_ENABLED=false               # Track all songs, syncs, and actions in a local SQLite DB
HISTORY_DB_FILE=cache/history.db       # Path to the history database file
HISTORY_MAX_SIZE_MB=0                  # Auto-prune oldest records when exceeded (0 = unlimited)
HISTORY_RETENTION_DAYS=0               # Auto-delete syncs & actions older than N days after each sync (0 = keep forever)

# ============================================================================
# RELIABILITY & RETRIES
# ============================================================================

API_MAX_RETRIES=3            # YTM API retry attempts (exponential backoff)
LASTFM_MAX_RETRIES=5         # Last.fm API retry attempts
LASTFM_MAX_CONSECUTIVE_EMPTY=3  # Stop after N pages with no new tracks
LASTFM_FORCE_IPV4=true       # Force IPv4 (helps with flaky Last.fm IPv6)

# ============================================================================
# AUTO-SYNC and frontend related - only works in combination with the frontend
# ============================================================================

AUTO_SYNC_ENABLED=false     # Enable automatic syncing
AUTO_SYNC_TYPE=interval     # interval|cron
AUTO_SYNC_INTERVAL_HOURS=6  # How often to sync (e.g., 6 = every 6 hours)
AUTO_SYNC_CRON=0 */6 * * *  # Standard cron format: minute hour day month weekday (server time)
AUTO_TAG_SYNC_ENABLED=false  # Also sync custom tag-based playlists after each scheduled run
AUTO_TAG_SYNC_FREQUENCY=1   # Run tag sync every N main syncs (1 = every time, 3 = every 3rd)
USE_24_HOUR_CLOCK=true      # Display times in 24-hour format (14:30) instead of 12-hour (2:30 PM)
DATE_FORMAT=auto            # Date display format: auto (browser locale), DMY (31/12), MDY (12/31)
NOW_PLAYING_ENABLED=true    # Show "Now Playing" from Last.fm in the header
NOW_PLAYING_INTERVAL=15     # How often to poll for now playing (5-120 seconds)
DISPLAY_TIPS=true           # Show the helper info banners at the top of each tab

# ============================================================================
# LOGGING
# ============================================================================

LOG_LEVEL=INFO               # CRITICAL|ERROR|WARNING|INFO|DEBUG

# ============================================================================
# WEBHOOKS
# ============================================================================

WEBHOOK_URL=                 # URL to POST sync results to (e.g., https://ntfy.sh/mytopic)
WEBHOOK_EVENTS=error         # all = every sync, error = only on failure
WEBHOOK_ALLOW_PRIVATE=false  # true = allow private/LAN/localhost webhook URLs (self-hosted ntfy/Gotify)

# ============================================================================
# AUTO-GENERATED (managed by the app - do not edit manually)
# ============================================================================
# The app writes values here on first boot. Do not set these yourself;
# they will be overwritten or cause conflicts.
#
# FLASK_SECRET_KEY=<auto-generated 32-byte hex, written by the app>
