# Python virtual environment
.venv/
.venv-docs/

# Python cache files
__pycache__/
*.py[cod]
*$py.class
.ruff_cache/

# Test / coverage artifacts
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# Distribution / packaging
*.egg-info/
dist/
build/
site/

# Environment variables
.env
browser.json

# Generated at Docker build time by run-docker.sh
COMMIT_SHA
.channel

# Cache directory
/cache/

# IDE specific files
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# Logs
*.log

# Backup files
*.bak

# JS tooling
node_modules/

# Translations (compiled)
*.mo
*.pot

# misc
.github/*
!.github/workflows/
!.github/workflows/**
!.github/dependabot.yml
!.github/ISSUE_TEMPLATE/
!.github/ISSUE_TEMPLATE/**
!.github/PULL_REQUEST_TEMPLATE.md
!.github/CODEOWNERS
!.github/SUPPORT.md
# Config files
config/*.json
!config/*.example
!config/*.json.example

# Screenshot automation - SQLite DB is regenerated from seed data each run
tests/screenshots/fixtures/cache/*.db
tests/screenshots/fixtures/cache/*.db-shm
tests/screenshots/fixtures/cache/*.db-wal
