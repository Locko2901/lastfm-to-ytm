# Python virtual environment
.venv/
.venv-docs/

# Python cache files
__pycache__/
*.py[cod]
*$py.class
.ruff_cache/

# Distribution / packaging
*.egg-info/
dist/
build/
site/

# Environment variables
.env
browser.json

# Generated at Docker build time by run-docker.sh
COMMIT_SHA
.channel

# Cache directory
/cache/

# IDE specific files
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# Logs
*.log

# JS tooling
node_modules/

# Translations (compiled)
*.mo
*.pot

# misc
.github/*
!.github/workflows/
!.github/workflows/**
# Config files
config/search_overrides.json
config/custom_playlists.json
config/tag_overrides.json

# Screenshot automation – SQLite DB is regenerated from seed data each run
tests/screenshots/fixtures/cache/*.db
tests/screenshots/fixtures/cache/*.db-shm
tests/screenshots/fixtures/cache/*.db-wal
